{
    "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
    "formatter": {
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 80,
        "lineEnding": "lf"
    },
    "linter": {
        "enabled": true
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "jsxQuoteStyle": "double",
            "semicolons": "always",
            "trailingCommas": "es5",
            "bracketSpacing": true,
            "arrowParentheses": "always"
        }
    },
    "json": {
        "formatter": {
            "trailingCommas": "none",
            "bracketSpacing": true
        }
    }
}
