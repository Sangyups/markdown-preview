{
    "name": "markdown-preview",
    "version": "1.2.0",
    "private": true,
    "bin": {
        "mdp": "./bin/markdown-preview.js"
    },
    "files": [
        "bin",
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "bun run scripts/build.ts",
        "dev": "bun run scripts/dev.ts",
        "start": "bun run dist/cli/index.js",
        "prepare": "bun run build",
        "check": "biome check README.md biome.json package.json tsconfig.json scripts src test",
        "format": "biome format --write README.md biome.json package.json tsconfig.json scripts src test",
        "test": "bun test",
        "pack": "bun pm pack"
    },
    "dependencies": {
        "electron": "^41.3.0",
        "highlight.js": "^11.11.1",
        "js-toml": "^1.1.0",
        "markdown-it": "^14.1.1",
        "markdown-it-footnote": "^4.0.0",
        "mermaid": "^11.14.0",
        "yaml": "^2.8.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@types/bun": "^1.3.13",
        "@types/markdown-it-footnote": "^3.0.4",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.3"
    }
}
