{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "types": ["bun-types", "node"],
        "lib": ["ES2022", "DOM", "DOM.Iterable"]
    },
    "include": ["src/**/*.ts", "scripts/**/*.ts", "test/**/*.ts"]
}
